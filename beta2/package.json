{
  "name": "antarctidum",
  "version": "0.0.2",
  "description": "Antarctidum — Modern Code Editor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.antarctidum.editor",
    "productName": "Antarctidum",
    "directories": { "output": "dist" },
    "files": [
      "main.js",
      "preload.js",
      "default-settings.json",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "monaco-editor": "^0.45.0",
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  }
}