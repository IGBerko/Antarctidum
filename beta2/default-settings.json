{
  "editor.fontSize": 14,
  "editor.fontFamily": "'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace",
  "editor.tabSize": 2,
  "editor.wordWrap": "off",
  "editor.minimap": true,
  "editor.lineNumbers": true,
  "editor.bracketPairColorization": true,
  "editor.autoSave": false,
  "editor.autoSaveDelay": 1000,
  "editor.renderWhitespace": "none",
  "editor.smoothScrolling": true,
  "editor.cursorBlinking": "smooth",
  "editor.cursorStyle": "line",
  "editor.formatOnSave": false,
  "editor.formatOnPaste": false,
  "terminal.fontSize": 13,
  "terminal.fontFamily": "'Cascadia Code', 'Fira Code', monospace",
  "terminal.shell": "",
  "appearance.theme": "dark",
  "appearance.language": "en",
  "appearance.zoomLevel": 0,
  "files.exclude": ["node_modules", ".git", "dist", "__pycache__", ".DS_Store"],
  "plugins.serverUrl": "https://antarctidum.itrypro.ru/plugins",
  "run.saveBeforeRun": true,
  "run.clearBeforeRun": true,
  "run.pythonPath": "python",
  "run.javaPath": "java",
  "run.javacPath": "javac",
  "run.nodePath": "node",
  "run.gccPath": "gcc",
  "run.gppPath": "g++",
  "run.phpPath": "php"
}